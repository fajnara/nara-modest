# ── Sanity Configuration ──────────────────────────────
# Dapatkan dari https://sanity.io/manage (project ID, dataset name)

NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-15

# ── Sanity Write Token ────────────────────────────────
# Dibutuhkan untuk: admin panel CRUD, seed script, upload foto
# Buat di: Sanity dashboard → API → Tokens → Add token
# Permission: WAJIB pilih "Developer" (Editor tidak cukup)

SANITY_WRITE_TOKEN=your_developer_token_here

# ── NextAuth Configuration ────────────────────────────
# NEXTAUTH_SECRET: random string untuk encrypt JWT
# Generate: openssl rand -base64 32
# Atau di Windows: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

NEXTAUTH_SECRET=your_random_secret_min_32_chars

# NEXTAUTH_URL: URL website kamu (dev = localhost, prod = vercel domain)
# Penting: tidak boleh ada trailing slash

NEXTAUTH_URL=http://localhost:3000

# ── Sanity Webhook (instant revalidation) ─────────────
# Untuk auto-update website setiap kali publish di Sanity Studio.
# Setup di: sanity.io/manage → API → Webhooks
# Secret bebas — pakai random string yang sama di Sanity webhook config.

SANITY_REVALIDATE_SECRET=random_secret_for_webhook

# ── Email (untuk fitur Lupa Password) ─────────────────
# Diperlukan agar admin bisa reset password sendiri via email.
# Resend gratis 3000 email/bulan: https://resend.com
# - Daftar → Verify domain → API Keys → Create API Key
# - Pakai onboarding@resend.dev untuk testing tanpa verify domain
#
# Format RESEND_FROM_EMAIL: "Nama Pengirim <email@yourdomain.com>"
# Contoh production: "Nara Modest <noreply@naramodest.com>"
# Contoh testing:    "Nara Modest <onboarding@resend.dev>"

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Toko Kamu <onboarding@resend.dev>

# ── Optional: Initial Admin Creation ──────────────────
# Dipakai HANYA saat menjalankan `npm run create-admin`.
# Hapus baris ini setelah admin user pertama berhasil dibuat,
# atau jangan commit kredensial asli ke git.
#
# Aturan password:
#   - Minimal 10 karakter
#   - Wajib mengandung huruf DAN angka
#   - Tidak boleh sama dengan email
#
# ADMIN_NAME=Nama Kamu
# ADMIN_EMAIL=admin@toko.com
# ADMIN_PASSWORD=passwordAman123
# ADMIN_ROLE=superadmin
